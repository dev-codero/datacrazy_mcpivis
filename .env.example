# DataCrazy CRM — environment variables
# Copie para `.env` e preencha os valores reais.
# O `.env` está no .gitignore — NUNCA comite credenciais.

# (obrigatório) JWT da API DataCrazy (header `access-token`)
DATACRAZY_API_TOKEN=<cole_seu_token_aqui>

# (opcional) Base URL da REST API legada. Default: https://api.g1.datacrazy.io
# (a URL /v1/api/openapi/v1/json servida aí documenta o schema das tools)
# DATACRAZY_API_URL=https://api.g1.datacrazy.io

# (opcional) URL do MCP JSON-RPC oficial. Default: https://mcp.g1.datacrazy.io/api/mcp
# Esta é a URL que funciona com o token atual.
# DATACRAZY_MCP_URL=https://mcp.g1.datacrazy.io/api/mcp

# (opcional) Safe mode para operações destrutivas (delete_*, lose_business, finish_conversation).
# `true`  (default) → exige `confirm: true` na chamada
# `false`            → executa imediatamente
# SAFE_MODE=true

# ─── n8n sync ───────────────────────────────────────────────────────────────
# URL do webhook do n8n que roteia para as planilhas Google
# "NOVA_LUZ_LEAD_QUALIFICADO" / "NOVA_LUZ_LEAD_CONVERTIDO" via campo `etapa`.
# N8N_WEBHOOK_URL=https://n8m.conversoai.com.br/webhook/3394ed04-1c67-4bae-89ec-ee71f46b6d95

# (opcional) Dry-run global do sync n8n. Default: true (NÃO envia, só loga).
# Só setar `false` em produção após testar.
# N8N_DRY_RUN=true
